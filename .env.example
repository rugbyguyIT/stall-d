# Copy to .env for local dev (vite exposes SUPABASE_URL / SUPABASE_ANON_KEY
# to the client via envPrefix; the service role key is used ONLY by the
# Netlify functions and is never bundled).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # netlify functions only
